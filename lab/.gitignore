!references/spring-irs/smac2023/fig7a-full-modal-model.wav
!renders/.gitkeep
!reports/.gitkeep
!stimuli/.gitkeep

# Tool caches.
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

