!references/nam/manifests/*.json
!references/nam/renders/
references/nam/renders/*
!references/nam/renders/.gitkeep
!references/tone3000-inputs/
references/tone3000-inputs/*
!references/tone3000-inputs/.gitkeep
!references/tone3000-irs/
references/tone3000-irs/*
!references/tone3000-irs/.gitkeep
!references/spring-irs/
