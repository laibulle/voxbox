{
  // Diagnostic Nox30 rig: volume and drive fully open for sag/compression checks.
  name: 'nox30-dimed',

  chain: {
    cable_capacitance_pf: 470,
  },

  amp: {
    model: 'nox30',
    bypassed: false,
    controls: {
      volume: 1.0,
      bass: 0.52,
      treble: 0.61,
      cut: 0.47,
      drive: 1.0,
      presence: 0.44,
      sag: 0.70,
    },
  },
}
